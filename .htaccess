RewriteEngine On
RewriteBase /

# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Main site
RewriteRule ^register/?$ register.php [L]
RewriteRule ^qr-image/?$ qr-image.php [L,QSA]
RewriteRule ^gallery/?$ gallery.php [L]
RewriteRule ^gifts/?$ gifts.php [L]
RewriteRule ^well-wishes/?$ well-wishes.php [L]
RewriteRule ^index/?$ index.php [L]
RewriteRule ^$ index.php [L]

# Admin
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/dashboard/?$ admin/dashboard.php [L]
RewriteRule ^admin/guests/?$ admin/guests.php [L]
RewriteRule ^admin/scan/?$ admin/scan.php [L,QSA]
RewriteRule ^admin/guest-card/?$ admin/guest-card.php [L,QSA]
RewriteRule ^admin/guest-edit/?$ admin/guest-edit.php [L,QSA]
RewriteRule ^admin/gifts/?$ admin/gifts.php [L]
RewriteRule ^admin/gift-edit/?$ admin/gift-edit.php [L,QSA]
RewriteRule ^admin/receipts/?$ admin/receipts.php [L]
RewriteRule ^admin/well-wishes/?$ admin/well-wishes.php [L]
RewriteRule ^admin/gallery/?$ admin/gallery.php [L]
RewriteRule ^admin/logout/?$ admin/logout.php [L]
